{
  "name": "dusubs",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/make-dict.js && node scripts/build-ja-dict.js",
    "build": "esbuild popup.tsx --bundle --outfile=popup.bundle.js --jsx=automatic --jsx-import-source=preact",
    "watch": "esbuild popup.tsx --bundle --outfile=popup.bundle.js --jsx=automatic --jsx-import-source=preact --watch",
    "build:ja-dict": "node scripts/build-ja-dict.js"
  },
  "devDependencies": {
    "esbuild": "^0.23.0",
    "preact": "^10.24.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@sglkc/kuromoji": "^1.1.0",
    "kuromoji": "^0.1.2"
  }
}
