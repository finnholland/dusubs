{
  "manifest_version": 2,
  "name": "Dusubs",
  "version": "1.0",
  "description": "Dual subtitles with pinyin, descriptions, and saving to lists",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "webRequest",
    "https://www.dusubs.com/*",
    "*://*.youtube.com/*",
    "*://*.bilibili.com/*",
    "*://*.bilivideo.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "content_scripts": [
    {
      "world": "MAIN",
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "youtube-main.js"
      ]
    },
    {
      "world": "MAIN",
      "matches": [
        "https://www.bilibili.com/*"
      ],
      "js": [
        "bilibili-main.js"
      ]
    },
    {
      "world": "ISOLATED",
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*",
        "https://www.bilibili.com/*"
      ],
      "js": [
        "pinyin-pro.js",
        "kuromoji.js",
        "content.js"
      ]
    },
    {
      "world": "ISOLATED",
      "matches": [
        "http://localhost/*",
        "https://www.dusubs.com/*"
      ],
      "js": [
        "web-bridge.js"
      ]
    }
  ],
  "icons": {
    "512": "icon.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Hanzi Pinyin Subtitles",
    "default_icon": {
      "512": "icon.png"
    }
  },
  "web_accessible_resources": [
    "cedict.json",
    "ja-dict.json",
    "dict/base.dat.gz",
    "dict/check.dat.gz",
    "dict/tid.dat.gz",
    "dict/tid_pos.dat.gz",
    "dict/tid_map.dat.gz",
    "dict/unk.dat.gz",
    "dict/unk_pos.dat.gz",
    "dict/unk_map.dat.gz",
    "dict/unk_char.dat.gz",
    "dict/unk_compat.dat.gz",
    "dict/unk_invoke.dat.gz",
    "dict/cc.dat.gz"
  ]
}
